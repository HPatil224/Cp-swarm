# Copy this file to .env and fill in real values. Never commit .env itself.

# --- LLM provider (Anthropic or Google Gemini) ---
# Set one of these keys. The swarm will automatically choose Gemini if GEMINI_API_KEY is present
# or if your model names contain "gemini".
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Model selection per agent (override defaults in config/settings.py if needed)
# For Anthropic (e.g. claude-3-5-sonnet-20260229) or Gemini (e.g. gemini-1.5-pro, gemini-1.5-flash)
MATHEMATICIAN_MODEL=claude-sonnet-4-6
ARCHITECT_MODEL=claude-sonnet-4-6
ADVERSARY_MODEL=claude-sonnet-4-6

# --- Execution sandbox limits ---
CPP_COMPILE_TIMEOUT_SECONDS=10
CPP_RUN_TIMEOUT_SECONDS=5
CPP_MEMORY_LIMIT_MB=256

# --- Orchestrator policy ---
MAX_ARCHITECT_RETRIES=5
MAX_MATHEMATICIAN_ESCALATIONS=2

# --- Misc ---
LOG_LEVEL=INFO
WORKSPACE_DIR=./workspace
LOGS_DIR=./logs/runs
